// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum FamilyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimStatus {
  PENDING // Legacy
  INITIATED
  DOCUMENTS_PENDING
  PRE_VERIFIED
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

// Phase 5 — tracks whether a claim was AI-recommended or manually initiated
enum ClaimSource {
  AI_RECOMMENDED
  MANUAL
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  auditLogs          AuditLog[]
  families           Family[]
  recommendationLogs RecommendationLog[] // Phase 5

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Family {
  id                String       @id @default(uuid())
  temporaryFamilyId String       @unique
  status            FamilyStatus @default(PENDING)
  createdById       String
  createdAt         DateTime     @default(now())

  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members            FamilyMember[]
  claims             Claim[]
  recommendationLogs RecommendationLog[] // Phase 5

  @@map("families")
}

model FamilyMember {
  id                String   @id @default(uuid())
  familyId          String
  name              String
  phone             String
  aadhaarEncrypted  String
  aadhaarHash       String // SHA-256 of raw Aadhaar — used for duplicate detection
  panEncrypted      String?
  panHash           String? // SHA-256 of raw PAN — used for duplicate detection
  incomeRange       String
  occupation        String
  age               Int
  isAadhaarVerified Boolean  @default(false)
  isPanVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())

  family Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  claims Claim[]

  @@index([aadhaarHash])
  @@index([panHash])
  @@map("family_members")
}

model Claim {
  id        String      @id @default(uuid())
  familyId  String
  memberId  String
  schemeId  String
  status    ClaimStatus @default(PENDING)
  source    ClaimSource @default(MANUAL) // Phase 5 — AI_RECOMMENDED or MANUAL
  createdAt DateTime    @default(now())

  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("claims")
}

// ── Phase 5 — Recommendation Intelligence ─────────────────────────────────────

model RecommendationLog {
  id              String   @id @default(uuid())
  userId          String
  familyId        String
  // inputSnapshot: profile sent to AI (state, incomeRange, occupation, age, etc.)
  // NO Aadhaar, PAN, or encrypted fields stored here — data safety enforced
  inputSnapshot   Json
  // schemesSnapshot: exact AI response (schemeId, schemeName, benefitSummary, etc.)
  schemesSnapshot Json
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([createdAt])
  @@map("recommendation_logs")
}

// ── Phase 7 — Audit + Notification Layer ─────────────────────────────────────

enum NotificationType {
  CLAIM_SUBMITTED
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_SETTLED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  claimId   String
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@unique([userId, type, claimId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
