generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  role               Role                @default(USER)
  createdAt          DateTime            @default(now())
  auditLogs          AuditLog[]
  families           Family[]
  recommendationLogs RecommendationLog[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Family {
  id                 String              @id @default(uuid())
  temporaryFamilyId  String              @unique
  status             FamilyStatus        @default(PENDING)
  createdById        String
  createdAt          DateTime            @default(now())
  category           String              @default("General")
  state              String              @default("Andhra Pradesh")
  claims             Claim[]
  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members            FamilyMember[]
  documents          FamilyDocument[]
  recommendationLogs RecommendationLog[]

  @@map("families")
}

model FamilyDocument {
  id         String   @id @default(uuid())
  familyId   String
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("family_documents")
}

model FamilyMember {
  id                 String   @id @default(uuid())
  familyId           String
  nameAsInAadhaar    String
  phoneAsInAadhaar   String
  aadhaarEncrypted   String
  aadhaarHash        String
  panEncrypted       String?
  panHash            String?
  incomeRange        String
  occupation         String
  age                Int
  gender             String   @default("Male")
  religion           String   @default("Hindu")
  physicallyDisabled Boolean  @default(false)
  isAadhaarVerified  Boolean  @default(false)
  isPanVerified      Boolean  @default(false)
  createdAt          DateTime @default(now())
  claims            Claim[]
  family            Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([aadhaarHash])
  @@index([panHash])
  @@map("family_members")
}

model Claim {
  id        String       @id @default(uuid())
  familyId  String
  memberId  String
  schemeId  String
  category  ClaimCategory @default(SCHEME)
  metadata  Json?
  status    ClaimStatus  @default(PENDING)
  source    ClaimSource  @default(MANUAL)
  createdAt DateTime     @default(now())
  family    Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member    FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("claims")
}

model RecommendationLog {
  id              String   @id @default(uuid())
  userId          String
  familyId        String
  inputSnapshot   Json
  schemesSnapshot Json
  createdAt       DateTime @default(now())
  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([createdAt])
  @@map("recommendation_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  claimId   String
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@unique([userId, type, claimId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum Role {
  USER
  ADMIN
}

enum FamilyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClaimCategory {
  SCHEME
  POLICY
}

enum ClaimStatus {
  PENDING
  INITIATED
  DOCUMENTS_PENDING
  PRE_VERIFIED
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

enum ClaimSource {
  AI_RECOMMENDED
  MANUAL
}

enum NotificationType {
  CLAIM_SUBMITTED
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_SETTLED
}

model Orphan {
  id                 String              @id @default(uuid())
  tempId             String              @unique
  permanentId        String?             @unique
  name               String
  fatherName         String
  motherName         String
  guardianName       String?
  currentAddress     String
  aadhaarNumber      String?
  biometricsTaken    Boolean             @default(false)
  policeVerification VerificationStatus  @default(PENDING)
  createdAt          DateTime            @default(now())
  trustFund          TrustFund?

  @@map("orphans")
}

model TrustFund {
  id          String   @id @default(uuid())
  orphanId    String   @unique
  totalAmount Float
  balance     Float
  createdAt   DateTime @default(now())
  orphan      Orphan   @relation(fields: [orphanId], references: [id], onDelete: Cascade)
  transactions FundTransaction[]

  @@map("trust_funds")
}

model FundTransaction {
  id          String   @id @default(uuid())
  fundId      String
  amount      Float
  purpose     String
  toWhom      String
  proofDocUrl String?
  createdAt   DateTime @default(now())
  fund        TrustFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@map("fund_transactions")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}
