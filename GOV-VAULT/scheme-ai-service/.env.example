# ─── Scheme AI Service ────────────────────────────────────────────────────────

# Pinecone vector database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_HOST=https://scheme-data-xxxx.svc.xxxx.pinecone.io

# Groq LLM (llama3-70b-8192)
GROQ_API_KEY=your_groq_api_key_here

# Path to Scheme Saathi source (used by engine.py sys.path injection)
# Local dev: absolute path to D:\capstone\Scheme_Saathi
# Docker:    /scheme_saathi  (mounted volume — see docker-compose.yml)
SCHEME_SAATHI_PATH=D:\capstone\Scheme_Saathi

# Path to Scheme Saathi SQLite database (read-only)
# Local dev: absolute path to new_schemes.db
# Docker:    /scheme_saathi/new_schemes.db
DB_PATH=D:\capstone\Scheme_Saathi\new_schemes.db
