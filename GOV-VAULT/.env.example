# ─────────────────────────────────────────────────────────
#  GOV-VAULT — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://govvault_user:govvault_pass@localhost:5432/govvaultdb"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_SUPER_SECRET_KEY_MIN_32_CHARS"
JWT_EXPIRES_IN="7d"

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ── Encryption (Phase 2) ──────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS_GENERATED_ABOVE_________________________________"

# ── Scheme AI Service (Phase 4) ───────────────────────────
# Pinecone vector DB — get from your Pinecone dashboard
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_HOST="https://scheme-data-xxxx.svc.xxxx.pinecone.io"

# Groq LLM (llama3-70b-8192)
GROQ_API_KEY="your_groq_api_key_here"

# AI service URL
# Local dev: http://localhost:8000
# Docker: http://scheme-ai-service:8000 (auto-set in docker-compose)
AI_SERVICE_URL="http://localhost:8000"

# Absolute path to Scheme_Saathi dir (used for Docker bind mount volume)
SCHEME_SAATHI_DIR="../Scheme_Saathi"
